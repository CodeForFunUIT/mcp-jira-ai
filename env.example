# ─────────────────────────────────────────────
# VNPT Dev Agent — Environment Variables
# Copy file này thành .env và điền vào
# KHÔNG commit file .env lên git!
# ─────────────────────────────────────────────

# Jira Configuration
# URL gốc của Jira nội bộ VNPT (không có dấu / ở cuối)
JIRA_BASE_URL=https://one-ai.vnpt.vn

# Personal Access Token — lấy tại:
# Jira → Profile → Personal Access Tokens → Create Token
JIRA_PAT=your_personal_access_token_here

# (Optional) Project key mặc định nếu chỉ làm 1 project
JIRA_DEFAULT_PROJECT=VNPTAI

# ─────────────────────────────────────────────
# FEEDBACK LOOP — BỔ SUNG #5
# ─────────────────────────────────────────────

# Nơi lưu feedback (mặc định: feedback-store.json trong thư mục chạy)
# Có thể override nếu muốn lưu ở chỗ khác
# FEEDBACK_STORE_PATH=D:/projects/vnpt-dev-agent/feedback-store.json
